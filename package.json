{
  "name": "gx",
  "version": "1.1.24",
  "description": "Git Extended — batch PR creation, safe merge, and git workflow automation",
  "type": "module",
  "bin": {
    "gx": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "build:binary": "bun build --compile ./src/index.ts --outfile dist/gx",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && oxlint src/",
    "lint:ox": "oxlint src/",
    "lint:tsc": "tsc --noEmit",
    "verify": "pnpm run lint && pnpm run build && pnpm run test",
    "prepublishOnly": "pnpm run verify"
  },
  "keywords": [
    "git",
    "github",
    "pr",
    "pull-request",
    "merge",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^9.4.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "oxlint": "^1.74.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  }
}
